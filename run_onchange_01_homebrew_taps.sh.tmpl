{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash

set -eufo pipefail

{{ template "homebrew_path_setup" . }}

# Ensure brew is available before running
if ! command -v brew &>/dev/null; then
    echo "Homebrew not found, skipping package installation"
    exit 0
fi

# Ensure Homebrew's package index is up to date (critical on fresh installs)
echo "Updating Homebrew..."
brew update

brew bundle --file=/dev/stdin <<EOF
tap "asheshgoplani/tap"
tap "hashicorp/tap"
tap "jandedobbeleer/oh-my-posh"
tap "sst/tap"
tap "felixkratz/formulae"
tap "veirt/veirt"
tap "manaflow-ai/cmux"

## mas "MyScript Notes for Students", id: 1119601770
EOF
{{ end -}}
