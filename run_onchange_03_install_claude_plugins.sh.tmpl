#!/usr/bin/env bash
# Install Claude Code plugins
# This script runs whenever the plugin list changes.
{{ template "error_handling" . }}

CLAUDE_BIN="${HOME}/.local/bin/claude"

if ! command -v claude &>/dev/null && [ ! -x "${CLAUDE_BIN}" ]; then
  echo "Claude Code not found, skipping plugin installation"
  exit 0
fi

CLAUDE="${CLAUDE_BIN}"
if command -v claude &>/dev/null; then
  CLAUDE="claude"
fi

# Custom marketplaces to register before installing plugins.
MARKETPLACES=(
  "affaan-m/everything-claude-code"
  "nextlevelbuilder/ui-ux-pro-max-skill"
  "vercel-labs/agent-browser"
  "vercel-labs/skills"
  "wshobson/agents"
)

echo "Registering custom marketplaces..."
for marketplace in "${MARKETPLACES[@]}"; do
  echo "  → ${marketplace}"
  "${CLAUDE}" plugin marketplace add "${marketplace}" 2>/dev/null || true
done

# Plugins to install — any change triggers a re-run.
PLUGINS=(
  "claude-code-setup@claude-plugins-official"
  "claude-md-management@claude-plugins-official"
  "code-review@claude-plugins-official"
  "code-simplifier@claude-plugins-official"
  "commit-commands@claude-plugins-official"
  "context7@claude-plugins-official"
  "everything-claude-code@everything-claude-code"
  "feature-dev@claude-plugins-official"
  "frontend-design@claude-plugins-official"
  "pyright-lsp@claude-plugins-official"
  "ralph-loop@claude-plugins-official"
  "rust-analyzer-lsp@claude-plugins-official"
  "security-guidance@claude-plugins-official"
  "serena@claude-plugins-official"
  "skill-creator@claude-plugins-official"
  "supabase@claude-plugins-official"
  "superpowers@claude-plugins-official"
  "swift-lsp@claude-plugins-official"
  "typescript-lsp@claude-plugins-official"
  "ui-ux-pro-max@ui-ux-pro-max-skill"
  "agent-browser@agent-browser"
  "find-skills@vercel-labs-skills"
)

echo "Installing Claude Code plugins..."
for plugin in "${PLUGINS[@]}"; do
  echo "  → ${plugin}"
  "${CLAUDE}" plugin install "${plugin}" 2>/dev/null || true
done

# Skills installed via skills.sh (npx skills) — symlinked to ~/.claude/skills/
SKILLS=(
  "https://github.com/coreyhaines31/marketingskills --skill seo-audit"
  "https://github.com/anthropics/skills --skill frontend-design"
)

if command -v npx &>/dev/null; then
  echo "Installing skills.sh skills..."
  for skill in "${SKILLS[@]}"; do
    echo "  → ${skill}"
    npx -y skills add ${skill} --yes --global 2>/dev/null || true
  done
fi

echo "Claude Code plugins and skills installed."
