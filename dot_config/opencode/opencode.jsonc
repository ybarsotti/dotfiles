{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-5",
  "small_model": "openai/gpt-5.4-mini",
  "autoupdate": true,
  "plugin": [
    "opencode-anthropic-oauth@latest",
    "@franlol/opencode-md-table-formatter@0.0.3",
    "@mohak34/opencode-notifier@latest",
    "@zenobius/opencode-skillful",
    "@plannotator/opencode@latest",
    "octto",
    "oh-my-openagent@latest"
  ],
  "provider": {
    "anthropic": {
      "models": {
        "claude-sonnet-5": {
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            }
          }
        },
        "claude-opus-4-8": {
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 32000
            }
          }
        }
      }
    },
    "openai": {
      "models": {
        "gpt-5.5": {
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "medium"
          }
        },
        "gpt-5.4-mini": {
          "options": {
            "reasoningEffort": "medium",
            "textVerbosity": "low"
          }
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "gitnexus": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "gitnexus@latest",
        "mcp"
      ],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "codebuddy",
        "--project-from-cwd"
      ],
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "ai-memory": {
      "type": "remote",
      "url": "http://127.0.0.1:49374/mcp",
      "enabled": true
    }
  }
}
