layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zjstatus" {
                // ── Catppuccin Mocha ────────────────────────────────────
                color_rosewater "#f5e0dc"
                color_flamingo  "#f2cdcd"
                color_pink      "#f5c2e7"
                color_mauve     "#cba6f7"
                color_red       "#f38ba8"
                color_maroon    "#eba0ac"
                color_peach     "#fab387"
                color_yellow    "#f9e2af"
                color_green     "#a6e3a1"
                color_teal      "#94e2d5"
                color_sky       "#89dceb"
                color_sapphire  "#74c7ec"
                color_blue      "#89b4fa"
                color_lavender  "#b4befe"
                color_text      "#cdd6f4"
                color_subtext1  "#bac2de"
                color_subtext0  "#a6adc8"
                color_overlay2  "#9399b2"
                color_overlay1  "#7f849c"
                color_overlay0  "#6c7086"
                color_surface2  "#585b70"
                color_surface1  "#45475a"
                color_surface0  "#313244"
                color_base      "#1e1e2e"
                color_mantle    "#181825"
                color_crust     "#11111b"

                // ── Layout ──────────────────────────────────────────────
                format_left   "{mode} #[fg=$blue,bold]{session} #[fg=$overlay0]│ {tabs}"
                format_center ""
                format_right  "{command_git_branch}{command_git_status}{swap_layout}{notifications}{datetime}"
                format_space  "#[bg=$base]"
                format_hide_on_overlength "true"
                format_precedence         "lrc"

                border_enabled "false"
                hide_frame_for_single_pane "true"

                // ── Mode Indicators ─────────────────────────────────────
                mode_normal       "#[fg=$green]  "
                mode_locked       "#[fg=$red,bold]  "
                mode_resize       "#[fg=$yellow]  "
                mode_pane         "#[fg=$teal]  "
                mode_tab          "#[fg=$peach] 󰓩 "
                mode_scroll       "#[fg=$flamingo]  "
                mode_enter_search "#[fg=$mauve]  "
                mode_search       "#[fg=$mauve]  "
                mode_rename_tab   "#[fg=$peach] 󰏫 "
                mode_rename_pane  "#[fg=$peach] 󰏫 "
                mode_session      "#[fg=$lavender]  "
                mode_move         "#[fg=$sky]  "
                mode_prompt       "#[fg=$sapphire]  "
                mode_tmux         "#[fg=$mauve] 󰊠 "
                mode_default_to_mode "normal"

                // ── Tabs ────────────────────────────────────────────────
                tab_normal            "#[fg=$overlay1] {name} "
                tab_normal_fullscreen "#[fg=$overlay1] {name}{fullscreen_indicator} "
                tab_normal_sync       "#[fg=$overlay1] {name}{sync_indicator} "
                tab_active            "#[fg=$mauve,bold] {name} "
                tab_active_fullscreen "#[fg=$mauve,bold] {name}{fullscreen_indicator} "
                tab_active_sync       "#[fg=$green,bold] {name}{sync_indicator} "
                tab_separator         "#[fg=$surface2]⋮ "
                tab_rename            "#[fg=$peach,italic] {name} "
                tab_sync_indicator       " 󰓦"
                tab_fullscreen_indicator " 󰊓"
                tab_floating_indicator   " 󰉈"

                // ── Git Branch ──────────────────────────────────────────
                command_git_branch_command    "bash -c 'git rev-parse --abbrev-ref HEAD 2>/dev/null'"
                command_git_branch_format     "#[fg=$blue]  {stdout} "
                command_git_branch_interval   "5"
                command_git_branch_rendermode "static"

                // ── Git Status (dirty/clean) ────────────────────────────
                command_git_status_command    "bash -c 'if [ -n \"$(git status --porcelain 2>/dev/null)\" ]; then echo \"●\"; fi'"
                command_git_status_format     "#[fg=$yellow]{stdout}"
                command_git_status_interval   "5"
                command_git_status_rendermode "static"

                // ── Swap Layout ─────────────────────────────────────────
                swap_layout_format       "#[fg=$overlay0,italic] 󰕰 {name} "
                swap_layout_hide_if_empty "true"

                // ── Notifications ───────────────────────────────────────
                notification_format_unread           "#[fg=$peach,bold] 󰂞 {message} "
                notification_format_no_notifications ""
                notification_show_interval           "10"

                // ── Date/Time ───────────────────────────────────────────
                datetime          "#[fg=$overlay2] {format}"
                datetime_format   " %a %d %b %H:%M"
                datetime_timezone "America/Sao_Paulo"
            }
        }
    }
}
