{{- /* chezmoi:modify-template */ -}}
{{- $json := .chezmoi.stdin | default "{}" | fromJson -}}
{{- $shared := .mcp_servers.shared -}}
{{- $typed := index .mcp_servers .machine.purpose -}}
{{- $managed := mergeOverwrite (dict) $shared $typed -}}
{{- $existing := $json.mcpServers | default dict -}}
{{- $all := mergeOverwrite (dict) $existing $managed -}}
{{ $json | setValueAtPath "mcpServers" $all | toPrettyJson }}
