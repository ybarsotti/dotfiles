{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash

# This script installs SDKs and language version managers.
# PATH setup happens after each section unconditionally so later steps
# always find tools installed by earlier steps, even on partial re-runs.

set -eufo pipefail

# --- Install Rust ---
if ! command -v cargo &>/dev/null; then
  echo "Installing Rust..."
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
else
  echo "Rust is already installed."
fi
# shellcheck source=/dev/null
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# --- Install mise ---
if ! command -v mise &>/dev/null; then
  echo "Installing mise..."
  curl https://mise.run | sh
else
  echo "mise is already installed."
fi
export PATH="$HOME/.local/bin:$PATH"
if command -v mise &>/dev/null; then
  echo "Setting up mise tools..."
  mise install
  mise plugins add lua
  mise use -g lua@5.1
  echo "Mise setup completed!"
fi

# --- Install uv (Python) ---
if ! command -v uv &>/dev/null; then
  echo "Installing uv..."
  curl -LsSf https://astral.sh/uv/install.sh | sh
else
  echo "uv is already installed."
fi

# --- Install Atuin ---
if ! command -v atuin &>/dev/null; then
  echo "Installing Atuin..."
  curl --proto '=https' --tlsv1.2 -LsSf https://setup.atuin.sh | sh
else
  echo "Atuin is already installed."
fi

# --- Install NVM + Node + pnpm ---
# NVM's shell scripts are not compatible with set -u (they reference unset
# variables), and NVM wraps node/npm with shell functions that also use them.
# Keep set +u active for the entire NVM/npm section.
set +u
export NVM_DIR="$HOME/.nvm"
if [ ! -d "$NVM_DIR" ]; then
  echo "Installing NVM..."
  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash
else
  echo "NVM is already installed."
fi

# Source NVM for this session (always, not just after install)
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

# Install node if not available
if ! command -v node &>/dev/null; then
  echo "Installing Node via NVM..."
  nvm install node
fi

# Install pnpm if not available
if ! command -v pnpm &>/dev/null; then
  echo "Installing pnpm..."
  npm install -g pnpm
else
  echo "pnpm is already installed."
fi
set -u
{{ end -}}
