{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash

# This script installs SDKs and language version managers.
# PATH setup happens after each section unconditionally so later steps
# always find tools installed by earlier steps, even on partial re-runs.

set -eufo pipefail

# --- Install Rust ---
if ! command -v cargo &>/dev/null; then
  echo "Installing Rust..."
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
else
  echo "Rust is already installed."
fi
# shellcheck source=/dev/null
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# --- Install mise ---
if ! command -v mise &>/dev/null; then
  echo "Installing mise..."
  curl https://mise.run | sh
else
  echo "mise is already installed."
fi
export PATH="$HOME/.local/bin:$PATH"
if command -v mise &>/dev/null; then
  echo "Setting up mise tools..."
  mise install
  mise plugins add lua
  mise use -g lua@5.1
  echo "Mise setup completed!"
fi

# --- Install uv (Python) ---
if ! command -v uv &>/dev/null; then
  echo "Installing uv..."
  curl -LsSf https://astral.sh/uv/install.sh | sh
else
  echo "uv is already installed."
fi

# --- Install Atuin ---
if ! command -v atuin &>/dev/null; then
  echo "Installing Atuin..."
  curl --proto '=https' --tlsv1.2 -LsSf https://setup.atuin.sh | sh
else
  echo "Atuin is already installed."
fi

# --- Install NVM + Node + pnpm ---
# NVM is a shell function that requires globbing (set +f) and allows unset
# vars (set +u). Keep set +uf active for the ENTIRE section — including PATH
# resolution and npm install — to avoid any noglob interference.
set +uf
export NVM_DIR="$HOME/.nvm"

# Install NVM if nvm.sh is not present
if [ ! -s "$NVM_DIR/nvm.sh" ]; then
  echo "Installing NVM..."
  [ -d "$NVM_DIR" ] && rm -rf "$NVM_DIR"
  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash
else
  echo "NVM is already installed."
fi

# shellcheck source=/dev/null
\. "$NVM_DIR/nvm.sh"

# Install node — check for actual binary, not just directory contents
# (previous failed runs may leave partial directories without a working binary)
NODE_BIN=$(find "$NVM_DIR/versions/node" -path "*/bin/node" -type f 2>/dev/null | head -1)
if [ -z "$NODE_BIN" ]; then
  echo "Installing Node via NVM..."
  rm -rf "${NVM_DIR:?}/versions/node/"*
  nvm install node
  nvm alias default node
  NODE_BIN=$(find "$NVM_DIR/versions/node" -path "*/bin/node" -type f 2>/dev/null | head -1)
fi

# Add node bin to PATH directly (nvm use is unreliable in non-interactive scripts)
if [ -n "$NODE_BIN" ]; then
  export PATH="$(dirname "$NODE_BIN"):$PATH"
  echo "Node $(node --version) ready"
else
  echo "WARNING: Failed to install node via NVM."
fi

# Install pnpm
if command -v npm &>/dev/null; then
  if ! command -v pnpm &>/dev/null; then
    echo "Installing pnpm..."
    npm install -g pnpm
  else
    echo "pnpm is already installed."
  fi
else
  echo "WARNING: npm not found. Skipping pnpm installation."
fi
set -uf
{{ end -}}
