#!/usr/bin/env bash
set -euo pipefail

json=$(cat)
[ -z "$json" ] && exit 0

title="Claude"
subtitle=$(basename "$(pwd)")
message=$(/opt/homebrew/bin/jq -r '.message // "Done"' <<< "$json" 2>/dev/null || echo "Done")
escaped=$(printf '%s' "$message" | sed 's/"/\\"/g')

osascript -e "display notification \"$escaped\" with title \"$title\" subtitle \"$subtitle\" sound name \"Tink\""
